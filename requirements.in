# PimPam — abstract backend dependencies
# Edit this file, then regenerate requirements.txt with:
#   uv pip compile requirements.in -o requirements.txt

# --- API framework ---
fastapi~=0.115
uvicorn[standard]~=0.32

# --- Validation & settings ---
pydantic[email]~=2.9
pydantic-settings~=2.6
python-multipart~=0.0.20     # form data & file uploads

# --- Database ---
sqlalchemy[asyncio]~=2.0     # [asyncio] extra pulls in greenlet
alembic~=1.14
asyncpg~=0.30                # async PostgreSQL driver
psycopg2-binary~=2.9         # sync driver (used by Alembic)

# --- Auth & security ---
passlib[bcrypt]~=1.7         # password hashing
bcrypt>=4.0,<5.0             # 5.0 broke passlib compatibility; prehash in security.py handles 72-byte limit
python-jose[cryptography]~=3.3  # JWT tokens
slowapi~=0.1                 # rate limiting
cryptography~=43.0           # RSA key generation, HTTP Signature signing/verification, Fernet AES encryption
pyotp~=2.9                   # TOTP 2FA (RFC 6238)

# --- Search ---
meilisearch~=0.31            # full-text search client (Meilisearch v1.x)

# --- Real-time ---
redis[asyncio]~=5.0          # pub/sub backend for WebSocket fan-out

# --- Federation ---
httpx~=0.28                  # outgoing AP requests (delivery, actor fetching)

# --- Media ---
pillow~=11.0                 # image processing and WebP conversion
boto3~=1.35                  # S3-compatible storage client (MinIO in dev, Cloudflare R2 in prod)

# --- Docs ---
sphinx~=8.0
furo~=2024.8                     # clean modern Sphinx theme

# --- Dev & testing ---
pytest~=8.3
pytest-asyncio~=0.24
pytest-cov~=6.0                  # coverage reporting
aiosqlite~=0.20                  # in-memory SQLite driver for tests
ruff~=0.9
black~=25.0
