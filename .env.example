# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Database ---
# Use postgresql+asyncpg:// for the async driver
DATABASE_URL=postgresql+asyncpg://pimpam:pimpam@localhost:5432/pimpam

# --- Auth ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173"]

# --- App ---
ENVIRONMENT=development

# --- Federation (ActivityPub) ---
# Set DOMAIN to your public hostname to enable federation with Mastodon, Pixelfed, Lemmy, etc.
# Must be reachable from the internet for federation to work.
DOMAIN=pimpam.social
FEDERATION_ENABLED=true
REMOTE_ACTOR_CACHE_TTL_SECONDS=86400
